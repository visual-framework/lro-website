  <h2 id="metrics" class="vf-u-margin--0 vf-u-padding__top--400">Metrics and tools</h2>

  <h3>Key metrics</h3>
  <ul class="vf-list vf-list--unordered">
    <li class="vf-list__item">Time to First Byte (TTFB)</li>
    <li class="vf-list__item">First Contentful Paint (FCP)</li>
    <li class="vf-list__item">Largest Contentful Paint (LCP)</li>
    <li class="vf-list__item">Total page size</li>
    <li class="vf-list__item">Number of network requests</li>
    <li class="vf-list__item">Cache hit ratio and timeout/error rate</li>
  </ul>

  <h3>Tools</h3>
  <ul class="vf-list vf-list--unordered">
    <li class="vf-list__item">Google Lighthouse</li>
    <li class="vf-list__item">WebPageTest</li>
    <li class="vf-list__item">Chrome DevTools network throttling</li>
    <li class="vf-list__item">Cloudflare or CloudFront analytics</li>
  </ul>
