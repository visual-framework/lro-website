    <li class="vf-list__item">Time to first byte (TTFB)</li>
    <li class="vf-list__item">Total page size</li>
    <li class="vf-list__item">Number of requests</li>
    <li class="vf-list__item">API response time</li>
    <li class="vf-list__item">Cache hit rate</li>
  </ul>

