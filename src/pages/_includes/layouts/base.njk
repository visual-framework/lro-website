{% set sidebarNav = [
  {
    title: "About",
    sectionTitle: "About",
    sectionHref: "/about/",
    sectionTag: "Framework",
    activePaths: ["/about/"],
    links: [
      { label: "Motivation and background",                 href: "/about/motivation-and-background/"},
      { label: "What is Low Resource Optimisation?",         href: "/about/what-is-lro/"},
      { label: "Who this framework is for?",                 href: "/about/who-this-is-for/"},
      { label: "Getting started",                           href: "/about/getting-started/"}
    ]
  },
  {
    title: "Optimisation principles",
    sectionTitle: "Optimisation principles",
    sectionHref: "/principles/",
    sectionTag: "Principles",
    activePaths: ["/principles/"],
    links: [
      { label: "Core content first",                         href: "/principles/core-content-first/"},
      { label: "Progressive enhancement",                    href: "/principles/progressive-enhancement/"},
      { label: "Graceful degradation",                       href: "/principles/graceful-degradation/"},
      { label: "Data transparency and user control",         href: "/principles/data-transparency-user-control/"},
      { label: "Page and interaction design principles",     href: "/principles/page-interaction-design-principles/"},
      { label: "Design patterns",                            href: "/principles/design-patterns/"},
      { label: "Anti patterns",                              href: "/principles/anti-patterns/"}
    ]
  },
  {
    title: "Frontend delivery and rendering",
    sectionTitle: "Frontend",
    sectionHref: "/frontend/",
    sectionTag: "Frontend",
    activePaths: ["/frontend/"],
    links: [
      { label: "Rendering strategies and impact",         href: "/frontend/rendering-strategies/"},
      { label: "JavaScript usage",                        href: "/frontend/javascript-usage/"},
      { label: "CSS usage",                               href: "/frontend/css-strategy/"},
      { label: "Third-party libraries",                   href: "/frontend/third-party-dependencies/"},
      { label: "Images and media",                        href: "/frontend/images-and-media/"},
      { label: "Fonts and icons strategy",                href: "/frontend/fonts-and-icons/"},
      { label: "Layout stability (CLS)",                  href: "/frontend/layout-stability/"}
    ]
  },
  {
    title: "System architecture and performance",
    activePaths: ["/system-architecture/", "/data-and-apis/", "/delivery-optimisation/", "/error-handling/"],
    links: [
      { label: "System design and optimisation",            href: "/system-architecture/system-design-optimisation/", exact: true },
      { label: "Data, APIs and Backend Efficiency",         href: "/system-architecture/data-apis-backend/"},
      { label: "Network and delivery optimisation",         href: "/system-architecture/network-delivery-optimisation/"},
      { label: "Security and performance metrics",          href: "/system-architecture/security-performance-metrics/"},
      { label: "Resilience and offline patterns",           href: "/system-architecture/resilience-offline-patterns"}
    ]
  },
  {
    title: "Measurement and testing",
    activePaths: ["/measurement-and-testing/"]
  },
  {
    title: "Adoption and governance",
    activePaths: ["/adoption/"],
    links: [
      { label: "Overview",                          href: "/adoption/", exact: true },
      { label: "Embedding LRO in development",      href: "/adoption/embedding-lro-in-development/"},
      { label: "Tiered implementation model",       href: "/adoption/tiered-implementation/"},
      { label: "Governance and compliance",         href: "/adoption/governance-compliance/"},
      { label: "Sustainability and roadmaps",       href: "/adoption/sustainability-roadmaps/"}
    ]
  },
  {
    title: "Case studies and resources",
    activePaths: ["/applications/", "/reference/"],
    links: [
      { label: "Real-world examples", href: "/applications/real-world-examples/" },
      { label: "Glossary",   href: "/applications/glossary/"              }
    ]
  }
] %}

<!doctype html>
<html lang="en" class="vf-no-js">
  <head>
    {% render '@vf-no-js' -%}
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" media="all" href="{{ '/css/styles.css' | url }}"/>
    <link rel="stylesheet" media="all" href="{{ '/css/custom-overrides.css' | url }}"/>
    <title>
      {% if title and title !== siteConfig.siteInformation.title %}{{ title }} | {{ siteConfig.siteInformation.title }}
      {% else %}{{ siteConfig.siteInformation.title }}
      {% endif %}
    </title>
    <link href="{{ siteConfig.siteInformation.url }}feed.xml" type="application/rss+xml" rel="alternate" title="{{ siteConfig.siteInformation.title }} RSS Feed">
    {% render '@vf-favicon' -%}

    <!-- Descriptive meta -->
    <meta name="title" content="{% if title %}{{ title }} | {% endif %}{{ siteConfig.siteInformation.title }}">
    <meta name="author" content="{{ meta.author or siteConfig.siteInformation.author }}">
    <meta name="robots" content="index, follow">
    <meta name="keywords" content="{{ meta.keywords or 'LRO, low resource optimisation, performance, life science, EMBL' }}">
    <meta name="description" content="{{ meta.description or siteConfig.siteInformation.short_description }}">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ siteConfig.siteInformation.url }}{{ page.url.slice(1) }}">
    <meta property="og:title" content="{% if title and title !== siteConfig.siteInformation.title %}{{ title }} | {{ siteConfig.siteInformation.title }}{% else %}{{ siteConfig.siteInformation.title }}{% endif %}">
    <meta property="og:description" content="{{ meta.description or siteConfig.siteInformation.short_description }}">
    {% if meta.image -%}
      <meta property="og:image" content="{{ meta.image | url }}">
    {%- endif %}

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="{{ siteConfig.siteInformation.url }}{{ page.url.slice(1) }}">
    <meta property="twitter:title" content="{% if title and title !== siteConfig.siteInformation.title %}{{ title }} | {{ siteConfig.siteInformation.title }}{% else %}{{ siteConfig.siteInformation.title }}{% endif %}">
    <meta property="twitter:description" content="{{ meta.description or siteConfig.siteInformation.short_description }}">
    {% if meta.image -%}
      <meta property="twitter:image" content="{{ meta.image | url }}">
    {%- endif %}
  </head>
  <body class="{{ bodyClass }}">
