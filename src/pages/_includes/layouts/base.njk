                  {% endfor %}
                </ul>
              </details>
            </li>
            {% endfor %}
          </ul>
        </nav> #}
    </aside>

    <main class="lro-main-content vf-u-padding__left--800 vf-u-padding__right--800">
      {% if isArticlePage and title %}
        {% set directoryTitle = "" %}
        {% for section in sidebarNav %}
          {% for path in section.activePaths %}
            {% if page.url and (page.url == path or page.url.indexOf(path) == 0) %}
              {% set directoryTitle = section.sectionTitle or section.title %}
            {% endif %}
          {% endfor %}
        {% endfor %}
        <nav aria-label="Breadcrumb" class="vf-u-margin__top--400 vf-search-client-side--no-index">
          <p class="vf-intro__kicker">
            <a href="{{ '/' | url }}" class="vf-link">Home</a>
            {% if directoryTitle %}
              &nbsp;&gt;&nbsp;<span>{{ directoryTitle }}</span>
            {% endif %}
            &nbsp;&gt;&nbsp;<strong>{{ title }}</strong>
          </p>
        </nav>
      {% endif %}
      {{ content | safe }}
    </main>

  </div>

  {% include "footer.njk" %}

