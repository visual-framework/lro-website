          });
        }

        qAll("ul.vf-navigation__list a.vf-mega-menu__link--has-section").forEach(function (link) {
          link.addEventListener("click", function (e) {
            e.preventDefault();
            e.stopPropagation();
            var sectionid = link.getAttribute("data-vf-js-mega-menu-section-id");
            if (sectionid) {
              var section = document.querySelector('div [data-vf-js-mega-menu-section="' + sectionid + '"]');
