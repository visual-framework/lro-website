<!doctype html>
<html lang="en" class="vf-no-js">
  <head>
    {% render '@vf-no-js' -%}
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preload" href="{{ '/css/styles.css' | url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="{{ '/css/styles.css' | url }}"></noscript>
    {% if meta.hero_image and page.url == '/' %}
    <link rel="preload" as="image" href="{{ meta.hero_image | url }}" fetchpriority="high">
    {% endif %}
    {# <link rel="stylesheet" media="all" href="{{ '/style/custom-overrides.css' | url }}"/> #}
    <title>
      {% if title and title !== siteConfig.siteInformation.title %}{{ title }} | {{ siteConfig.siteInformation.title }}
      {% else %}{{ siteConfig.siteInformation.title }}
      {% endif %}
    </title>
    <link href="{{ siteConfig.siteInformation.url }}feed.xml" type="application/rss+xml" rel="alternate" title="{{ siteConfig.siteInformation.title }} RSS Feed">
    <link rel="shortcut icon" href="{{ '/images/favicon.ico' | url }}">
    <link rel="apple-touch-icon" sizes="180x180" href="{{ '/images/apple-touch-icon.png' | url }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ '/images/favicon-32x32.png' | url }}">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ '/images/favicon-16x16.png' | url }}">
    <link rel="manifest" href="{{ '/images/site.webmanifest' | url }}">
    <link rel="mask-icon" href="{{ '/images/safari-pinned-tab.svg' | url }}" color="#ffffff">
    <meta name="msapplication-TileColor" content="#ffffff">
    <meta name="theme-color" content="#ffffff">

    <!-- Descriptive meta -->
    <meta name="title" content="{% if title %}{{ title }} | {% endif %}{{ siteConfig.siteInformation.title }}">
    <meta name="author" content="EMBL-EBI Web Development Team">
    <meta name="robots" content="index, follow">
    <meta name="keywords" content="{{ meta.keywords or 'LRO, low resource optimisation, performance, life science, EMBL' }}">
    <meta name="description" content="{{ meta.description or siteConfig.siteInformation.short_description }}">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ siteConfig.siteInformation.url }}{{ page.url.slice(1) }}">
    <meta property="og:title" content="{% if title and title !== siteConfig.siteInformation.title %}{{ title }} | {{ siteConfig.siteInformation.title }}{% else %}{{ siteConfig.siteInformation.title }}{% endif %}">
    <meta property="og:description" content="{{ meta.description or siteConfig.siteInformation.short_description }}">
    {% if meta.image -%}
      <meta property="og:image" content="{{ meta.image | url }}">
    {%- endif %}

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="{{ siteConfig.siteInformation.url }}{{ page.url.slice(1) }}">
    <meta property="twitter:title" content="{% if title and title !== siteConfig.siteInformation.title %}{{ title }} | {{ siteConfig.siteInformation.title }}{% else %}{{ siteConfig.siteInformation.title }}{% endif %}">
    <meta property="twitter:description" content="{{ meta.description or siteConfig.siteInformation.short_description }}">
    {% if meta.image -%}
      <meta property="twitter:image" content="{{ meta.image | url }}">
    {%- endif %}
  </head>
  <body class="{{ bodyClass }}">

    {% include "header.njk" %}

    <div class="vf-grid lro-page-layout{% if page.url != '/' %} lro-page-layout--with-empty-right{% endif %}">

      {% include "sidebar.njk" %}

      <main class="lro-main-content vf-u-padding__left--800 vf-u-padding__right--800">
        {% if isArticlePage and title %}
          {# {% include "sidebar-nav-data.njk" %} #}
          {% set directoryTitle = "" %}
          {% set normalizedPageUrl = page.url or "/" %}
          {% if pathPrefix and normalizedPageUrl.indexOf(pathPrefix) == 0 %}
            {% set normalizedPageUrl = normalizedPageUrl.slice(pathPrefix.length) %}
          {% endif %}
          {% if normalizedPageUrl == "" %}
            {% set normalizedPageUrl = "/" %}
          {% endif %}
          {% for section in sidebarNav %}
            {% for path in section.activePaths %}
              {% if normalizedPageUrl == path or normalizedPageUrl.indexOf(path) == 0 %}
                {% set directoryTitle = section.sectionTitle or section.title %}
              {% endif %}
            {% endfor %}
          {% endfor %}
          <nav aria-label="Breadcrumb" class="vf-breadcrumbs vf-u-margin__left--0 vf-u-margin__top--200 vf-u-margin__bottom--200 vf-search-client-side--no-index">
            <ul class="vf-breadcrumbs__list | vf-list vf-list--inline">
              <li class="vf-breadcrumbs__item">
                <a href="{{ '/' | url }}" class="vf-breadcrumbs__link">Home</a>
              </li>
              {% if directoryTitle %}
              <li class="vf-breadcrumbs__item">
                <span>{{ directoryTitle }}</span>
              </li>
              {% endif %}
              <li class="vf-breadcrumbs__item" aria-current="page">
                <span>{{ title }}</span>
              </li>
            </ul>
          </nav>
        {% endif %}
        {{ content | safe }}
      </main>

    </div>

    {% include "footer.njk" %}

  </body>
</html>
