          <nav class="vf-navigation vf-navigation--global" aria-orientation="vertical">
            <ul class="vf-navigation__list | vf-list" data-vf-google-analytics-region="megamenu" role="menubar">
              {% for section in sidebarNav %}
                {% set hasSectionLinks = section.links and (section.links | length) > 0 %}
                <li class="vf-navigation__item" role="menuitem">
                  {% if hasSectionLinks %}
                    <a class="vf-navigation__link vf-mega-menu__link vf-mega-menu__link--has-section" href="{{ section.links[0].href | url }}" data-vf-js-mega-menu-section-id="{{ loop.index }}-menu-content-section" role="link" aria-expanded="false" aria-controls="{{ loop.index }}-menu-content-section">
                      {{ section.title }}
                    </a>
                  {% else %}
                    <a class="vf-navigation__link vf-mega-menu__link" href="{{ section.activePaths[0] | url }}" role="link">
                      {{ section.title }}
                    </a>
                  {% endif %}
                </li>
                <div class="responsive-only" style="display:none">
                  <div id="{{ loop.index }}-menu-content-section" data-vf-js-mega-menu-section="{{ loop.index }}-menu-content-section" role="menu" aria-hidden="true">
                    <ul class="vf-list">
                      {% for link in section.links %}
                        <li class="vf-list__item{% if page.url == link.href %} vf-list__item--active{% endif %}" role="menuitem">
                          <a href="{{ link.href | url }}" class="vf-link"{% if page.url == link.href %} aria-current="page"{% endif %}>{{ link.label }}</a>
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                </div>
              {% endfor %}
          </ul>
          {# <div class="vf-mega-menu__content__section vf-u-display-none searchbar-content-section" data-vf-js-mega-menu-section="search-menu-content-section" role="menu" aria-hidden="true" data-vf-google-analytics-region="megamenu-global-search">
                <form action="{{ '/search/' | url }}" class="vf-form vf-form--search vf-form--search--responsive | vf-sidebar vf-sidebar--end" role="search">
                    <div class="vf-sidebar__inner" role="menuitem">
                        <div class="vf-form__item">
                            <label id="search-menu-label" class="vf-form__label | vf-search__label ">Search</label>&nbsp;
                            <input type="search" name="query" placeholder="Search on Intranet" id="search-menu-input" class="vf-form__input" value="" aria-labelledby="search-menu-label" />
                        </div>

                        <button type="submit" class="vf-search__button | vf-button vf-button--primary">
                            <span class="vf-button__text">Search</span>

                            <svg role="none" class="vf-icon vf-icon--search-btn | vf-button__icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" version="1.1" xmlns:xlink="http://www.w3.org/1999/xlink" xmlns:svgjs="http://svgjs.com/svgjs" viewBox="0 0 140 140" width="140" height="140">
                                <g transform="matrix(5.833333333333333,0,0,5.833333333333333,0,0)">
                                    <path d="M23.414,20.591l-4.645-4.645a10.256,10.256,0,1,0-2.828,2.829l4.645,4.644a2.025,2.025,0,0,0,2.828,0A2,2,0,0,0,23.414,20.591ZM10.25,3.005A7.25,7.25,0,1,1,3,10.255,7.258,7.258,0,0,1,10.25,3.005Z" fill="#FFFFFF" stroke="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="0">
