<!-- Google tag (gtag.js) -->
<script>
  (function () {
    var host = (window.location && window.location.hostname ? window.location.hostname : "").toLowerCase();
    var isDevHost = host === "localhost" || host.indexOf("wwwdev") !== -1;
    var gaId = isDevHost ? "G-SJYQ3Y808H" : "G-7D873YGZNY";

    var gtagScript = document.createElement("script");
    gtagScript.async = true;
    gtagScript.src = "https://www.googletagmanager.com/gtag/js?id=" + gaId;
    document.head.appendChild(gtagScript);

    window.dataLayer = window.dataLayer || [];
    window.gtag = window.gtag || function () { window.dataLayer.push(arguments); };
    window.gtag("js", new Date());
    window.gtag("config", gaId);
  })();
</script>

{% render '@vf-polyfill-js' %}
<script src="{{ '/scripts/scripts.js' | url }}"></script>
<script>
  (function () {
    var toggles = document.querySelectorAll("[data-lro-mobile-toggle]");
    var panels = {
      menu: document.getElementById("lro-mobile-menu-panel"),
      search: document.getElementById("lro-mobile-search-panel")
    };

    if (!toggles.length || !panels.menu || !panels.search) {
      return;
    }

    function setActivePanel(nextPanel) {
      toggles.forEach(function (toggle) {
        var panelName = toggle.getAttribute("data-lro-mobile-toggle");
        var isActive = panelName === nextPanel;
        toggle.classList.toggle("is-active", isActive);
        toggle.setAttribute("aria-expanded", isActive ? "true" : "false");
      });

      Object.keys(panels).forEach(function (panelName) {
        panels[panelName].hidden = panelName !== nextPanel;
      });

      // Prevent body scroll when a panel is open
      document.body.classList.toggle("lro-mobile-panel-open", !!nextPanel);
    }

    toggles.forEach(function (toggle) {
      toggle.addEventListener("click", function () {
        var panelName = toggle.getAttribute("data-lro-mobile-toggle");
        var isOpen = toggle.getAttribute("aria-expanded") === "true";
        setActivePanel(isOpen ? null : panelName);

        if (!isOpen && panelName === "search") {
          var searchInput = document.getElementById("lro-mobile-search-input");
          if (searchInput) {
            searchInput.focus();
          }
        }
      });
    });

    window.addEventListener("resize", function () {
      if (window.innerWidth > 768) {
        setActivePanel(null);
      }
    });
  })();
</script>
