<!-- Google tag (gtag.js) - Lazy loaded after page interactive -->
<script>
  (function () {
    var host = (window.location && window.location.hostname ? window.location.hostname : "").toLowerCase();
    var isDevHost = host === "localhost" || host.indexOf("wwwdev") !== -1;
    var gaId = isDevHost ? "G-SJYQ3Y808H" : "G-7D873YGZNY";

    // Initialize stub dataLayer and gtag to avoid errors
    window.dataLayer = window.dataLayer || [];
    window.gtag = window.gtag || function () { window.dataLayer.push(arguments); };

    // Lazy-load GA script after page interactive
    var loadGA = function () {
      var gtagScript = document.createElement("script");
      gtagScript.async = true;
      gtagScript.src = "https://www.googletagmanager.com/gtag/js?id=" + gaId;
      document.head.appendChild(gtagScript);
      
      // Initialize tracking after script loads
      gtagScript.onload = function () {
        window.gtag("js", new Date());
        window.gtag("config", gaId);
      };
    };

    // Use requestIdleCallback if available, otherwise defer to load event
    if (window.requestIdleCallback) {
      window.requestIdleCallback(loadGA);
    } else {
      window.addEventListener("load", loadGA);
    }
  })();
</script>

{% render '@vf-polyfill-js' %}
<script src="{{ '/scripts/scripts.js' | url }}"></script>
<script>
  (function () {
    var toggles = document.querySelectorAll("[data-lro-mobile-toggle]");
    var panels = {
      menu: document.getElementById("lro-mobile-menu-panel"),
      search: document.getElementById("lro-mobile-search-panel")
    };

    if (!toggles.length || !panels.menu || !panels.search) {
      return;
    }

    var activePanel = null;
    var lastToggle = null;

    function getFocusableElements(panel) {
      if (!panel) return [];
      return Array.prototype.slice.call(panel.querySelectorAll(
        'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])'
      )).filter(function (element) {
        return !element.hasAttribute("hidden") && element.getAttribute("aria-hidden") !== "true";
      });
    }

    function trapFocusInActivePanel(event) {
      if (event.key !== "Tab" || !activePanel || !panels[activePanel]) {
        return;
      }

      var panel = panels[activePanel];
      var focusable = getFocusableElements(panel);
      if (!focusable.length) {
        return;
      }

      var first = focusable[0];
      var last = focusable[focusable.length - 1];

      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    }

    document.addEventListener("keydown", trapFocusInActivePanel);

    function setActivePanel(nextPanel) {
      activePanel = nextPanel;

      toggles.forEach(function (toggle) {
        var panelName = toggle.getAttribute("data-lro-mobile-toggle");
        var isActive = panelName === nextPanel;
        toggle.classList.toggle("is-active", isActive);
        toggle.setAttribute("aria-expanded", isActive ? "true" : "false");
      });

      Object.keys(panels).forEach(function (panelName) {
        panels[panelName].hidden = panelName !== nextPanel;
        panels[panelName].setAttribute("aria-hidden", panelName === nextPanel ? "false" : "true");
      });

      // Prevent body scroll when a panel is open
      document.body.classList.toggle("lro-mobile-panel-open", !!nextPanel);

      if (nextPanel) {
        var panel = panels[nextPanel];
        var focusable = getFocusableElements(panel);
        if (focusable.length) {
          focusable[0].focus();
        }
      } else if (lastToggle) {
        lastToggle.focus();
      }
    }

    toggles.forEach(function (toggle) {
      toggle.addEventListener("click", function () {
        lastToggle = toggle;
        var panelName = toggle.getAttribute("data-lro-mobile-toggle");
        var isOpen = toggle.getAttribute("aria-expanded") === "true";
        setActivePanel(isOpen ? null : panelName);

        if (!isOpen && panelName === "search") {
          var searchInput = document.getElementById("lro-mobile-search-input");
          if (searchInput) {
            searchInput.focus();
          }
        }
      });
    });

    window.addEventListener("resize", function () {
      if (window.innerWidth > 768) {
        setActivePanel(null);
      }
    });

    document.addEventListener("keydown", function (event) {
      if (event.key === "Escape" && activePanel && activePanel !== "search") {
        setActivePanel(null);
      }
    });
  })();
</script>
