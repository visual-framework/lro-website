  {# ── Metrics and Tools ── #}
  <h2 id="metrics" class="vf-u-margin--0 vf-u-padding__top--400">Metrics and Tools</h2>

  <h3>Key metrics</h3>
  <ul class="vf-list vf-list--unordered">
    <li class="vf-list__item">Font download size</li>
    <li class="vf-list__item">Total page weight</li>
    <li class="vf-list__item">Render blocking resources</li>
    <li class="vf-list__item">First contentful paint (FCP)</li>
  </ul>

  <h3>Recommended benchmarks for LRO</h3>
  <ul class="vf-list vf-list--unordered">
    <li class="vf-list__item">Total font payload &lt; 100 KB</li>
    <li class="vf-list__item">Number of font families ≤ 1</li>
    <li class="vf-list__item">Font weights ≤ 2</li>
  </ul>

